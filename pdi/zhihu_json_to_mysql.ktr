    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var name_clean = "";
if (name != null) {
    name_clean = name.toString().trim();
}
if (name_clean == "") {
    name_clean = "未知";
}

var gender_clean = -1;
if (gender != null) {
    gender_clean = parseInt(gender);
}

var gender_label_clean = "未知";
if (gender_clean == 1) {
    gender_label_clean = "男";
} else if (gender_clean == 0) {
    gender_label_clean = "女";
}

var answer_count_clean = 0;
if (answer_count != null &amp;&amp; parseInt(answer_count) >= 0) {
    answer_count_clean = parseInt(answer_count);
}

var articles_count_clean = 0;
if (articles_count != null &amp;&amp; parseInt(articles_count) >= 0) {
    articles_count_clean = parseInt(articles_count);
}

var follower_count_clean = 0;
if (follower_count != null &amp;&amp; parseInt(follower_count) >= 0) {
    follower_count_clean = parseInt(follower_count);
}

var following_count_clean = 0;
if (following_count != null &amp;&amp; parseInt(following_count) >= 0) {
    following_count_clean = parseInt(following_count);
}</jsScript_script>
      </jsScript>
    </jsScripts>
